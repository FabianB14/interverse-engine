{
  "name": "interverse-engine",
  "version": "0.0.0",
  "private": true,
  "description": "Interverse Engine \u2014 an AI-native 2D game framework for mobile party games, cozy games, and 2D RPGs",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @interverse/hello dev",
    "dev:room": "pnpm --filter @interverse/room dev",
    "dev:taps": "pnpm --filter @interverse/taps dev",
    "relay": "pnpm --filter @interverse/relay dev",
    "build": "pnpm -r --if-present build",
    "preview": "pnpm --filter @interverse/hello preview",
    "typecheck": "pnpm -r --if-present typecheck",
    "verify": "node scripts/verify.mjs",
    "verify:room": "node scripts/verify-room.mjs",
    "verify:net": "node scripts/verify-net.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev:blobvale": "pnpm --filter @interverse/blobvale dev",
    "verify:blobvale": "node scripts/verify-blobvale.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "playwright-core": "^1.61.1",
    "prettier": "^3.4.2",
    "qrcode-terminal": "^0.12.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
